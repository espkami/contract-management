# ============================================================
# 合同管理系统 - 环境变量配置
# 复制此文件为 .env 并根据实际情况修改
# ============================================================

# ------------------ 应用配置 ------------------
# 应用端口（本地访问端口）
APP_PORT=8000

# Docker 镜像地址（从 Docker Hub 拉取时填写）
# DOCKER_IMAGE=your-username/contract-management:latest

# ------------------ 安全配置 ------------------
# JWT 密钥（生产环境务必修改为随机字符串，至少 32 位）
JWT_SECRET_KEY=change_me_in_production_please

# Token 有效期（小时）
JWT_EXPIRE_HOURS=8

# ------------------ 数据库配置 ------------------
# 数据库路径（容器内绝对路径，不要修改）
DATABASE_URL=sqlite:////data/contracts.db

# 上传文件存储路径（容器内，不要修改）
UPLOAD_DIR=/data/uploads

# ------------------ 管理员账号 ------------------
# 首次启动时自动创建的默认管理员账号
# 修改后需要删除 data 卷重新启动才能生效
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@contract.com